# LilyGO T-Beam V1.1/V1.2 — ESP32 (BTDM, не BT5)
# Основные отличия от sdkconfig.defaults (ESP32-S3):
# - BTDM controller вместо BT5 controller
# - Другие имена опций pinning
# - Нет SPIRAM OPI (T-Beam: QSPI PSRAM 8MB)

CONFIG_ESP_TASK_WDT_TIMEOUT_S=30

CONFIG_BT_NIMBLE_HOST_TASK_STACK_SIZE=8192
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1
CONFIG_BT_NIMBLE_MAX_BONDS=1
CONFIG_BT_NIMBLE_MAX_CCCDS=2
CONFIG_BT_NIMBLE_MSYS1_BLOCK_COUNT=8

CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=512

CONFIG_HTTPD_WS_SUPPORT=y

CONFIG_ESP_SYSTEM_EVENT_QUEUE_SIZE=32

CONFIG_SPIRAM_ALLOW_STACK_EXTERNAL_MEMORY=y
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y

# ESP32 BTDM: coexistence
CONFIG_ESP_COEX_SW_COEXIST_ENABLE=y
CONFIG_BTDM_CTRL_PINNED_TO_CORE=1
CONFIG_BT_NIMBLE_PINNED_TO_CORE=1

CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=2
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=2
CONFIG_ESP_WIFI_MGMT_SBUF_NUM=6
CONFIG_ESP_WIFI_AMPDU_RX_ENABLED=n
CONFIG_ESP_WIFI_AMPDU_TX_ENABLED=n
CONFIG_ESP_WIFI_AMSDU_TX_ENABLED=n
CONFIG_ESP_WIFI_TASK_STACK_SIZE=2560
